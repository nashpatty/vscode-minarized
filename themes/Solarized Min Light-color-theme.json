    "semanticHighlighting": true,
    "semanticTokenColors": {
        "customLiteral": "#657b83",
        "newOperator": "#657b83",
        "numberLiteral": "#d33682",
        "stringLiteral": "#2aa198"
    },
    "tokenColors": [
        {
            "name": "keyword or other syntax",
            "scope": "punctuation.terminator,punctuation.quasi.element",
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "name": "entities",
            "scope": "entity.name,support.type.property-name.json",
            "settings": {
                "foreground": "#6c71c4"
            }
        },
        {
            "scope": "support.type,constant.character.escape",
            "settings": {
                "foreground": "#b58900"
            }
        },
        {
            "scope": "constant.language",
            "settings": {
                "foreground": "#d33682"
            }
        },
        {
            "name": "no highlight",
            "scope": "variable.other,string.unquoted.argument.shell,storage.type.object,storage.type.java,constant.other.option",
            "settings": {
                "foreground": "#657b83"
            }
        },
        {
            "scope": "entity.name.function,support.function,keyword.control.twig",
            "settings": {
                "foreground": "#268bd2"
            }
        },
        {
            "scope": [
                "meta.embedded",
                "source.groovy.embedded",
                "string meta.image.inline.markdown",
            ],
            "settings": {
                "foreground": "#657b83"
            }
        },
        {
            "scope": "emphasis",
            "settings": {
                "fontStyle": "italic"
            }
        },
        {
            "scope": "strong",
            "settings": {
                "fontStyle": "bold"
            }
        },
        {
            "name": "Comment",
            "scope": "comment",
            "settings": {
                "foreground": "#93a1a1",
                "fontStyle": "italic"
            }
        },
        {
            "name": "block comment",
            "scope": "comment.block",
            "settings": {
                "foreground": "#93a1a1",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "variable.other.enummember",
                "keyword.operator.plus.exponent",
                "keyword.operator.minus.exponent",
            ],
            "settings": {
                "foreground": "#d33682"
            }
        },
        {
            "scope": "constant.regexp",
            "settings": {
                "foreground": "#cb4b16"
            }
        },
        {
            "scope": "entity.name.tag",
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": [
                "entity.name.tag.css",
                "entity.name.tag.less"
            ],
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": "entity.other.attribute-name",
            "settings": {
                "foreground": "#6c71c4"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name.class.css",
                "source.css entity.other.attribute-name.class",
                "entity.other.attribute-name.id.css",
                "entity.other.attribute-name.parent-selector.css",
                "entity.other.attribute-name.parent.less",
                "source.css entity.other.attribute-name.pseudo-class",
                "entity.other.attribute-name.pseudo-element.css",
                "source.css.less entity.other.attribute-name.id",
                "entity.other.attribute-name.scss"
            ],
            "settings": {
                "foreground": "#b58900"
            }
        },
        {
            "scope": "invalid",
            "settings": {
                "foreground": "#dc322f"
            }
        },
        {
            "scope": "markup.underline",
            "settings": {
                "fontStyle": "underline"
            }
        },
        {
            "scope": "markup.bold",
            "settings": {
                "fontStyle": "bold",
                "foreground": "#859900"
            }
        },
        {
            "scope": "markup.heading",
            "settings": {
                "fontStyle": "bold",
                "foreground": "#859900"
            }
        },
        {
            "scope": "markup.italic",
            "settings": {
                "fontStyle": "italic"
            }
        },
        {
            "scope": "markup.strikethrough",
            "settings": {
                "fontStyle": "strikethrough"
            }
        },
        {
            "scope": "markup.inserted",
            "settings": {
                "foreground": "#d33682"
            }
        },
        {
            "scope": "markup.deleted",
            "settings": {
                "foreground": "#2aa198"
            }
        },
        {
            "scope": "markup.changed",
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": "punctuation.definition.quote.begin.markdown",
            "settings": {
                "foreground": "#2aa198"
            }
        },
        {
            "scope": "punctuation.definition.list.begin.markdown",
            "settings": {
                "foreground": "#268bd2"
            }
        },
        {
            "scope": "markup.inline.raw",
            "settings": {
                "foreground": "#2aa198"
            }
        },
        {
            "name": "brackets of XML/HTML tags",
            "scope": "punctuation.definition.tag",
            "settings": {
                "foreground": "#93a1a1"
            }
        },
        {
            "scope": [
                "meta.preprocessor",
                "entity.name.function.preprocessor"
            ],
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": "meta.preprocessor.string",
            "settings": {
                "foreground": "#2aa198"
            }
        },
        {
            "scope": "meta.preprocessor.numeric",
            "settings": {
                "foreground": "#d33682"
            }
        },
        {
            "scope": "meta.diff.header",
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": "storage",
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": "storage.type",
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": [
                "storage.modifier",
                "keyword.operator.noexcept"
            ],
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": [
                "string",
                "meta.embedded.assembly",
            ],
            "settings": {
                "foreground": "#2aa198"
            }
        },
        {
            "scope": "string.tag",
            "settings": {
                "foreground": "#2aa198"
            }
        },
        {
            "scope": "string.value",
            "settings": {
                "foreground": "#2aa198"
            }
        },
        {
            "scope": "string.regexp",
            "settings": {
                "foreground": "#2aa198"
            }
        },
        {
            "name": "String interpolation",
            "scope": [
                "punctuation.definition.template-expression.begin",
                "punctuation.definition.template-expression.end",
                "punctuation.section.embedded"
            ],
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "name": "Reset JavaScript string interpolation expression",
            "scope": [
                "meta.template.expression"
            ],
            "settings": {
                "foreground": "#657b83"
            }
        },
        {
            "scope": [
                "support.type.vendored.property-name",
                "support.type.property-name",
                "source.css variable",
                "source.coffee.embedded"
            ],
            "settings": {
                "foreground": "#657b83"
            }
        },
        {
            "scope": "keyword",
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": "keyword.control",
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": "keyword.operator",
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": [
                "keyword.operator.new",
                "keyword.operator.expression",
                "keyword.operator.cast",
                "keyword.operator.sizeof",
                "keyword.operator.alignof",
                "keyword.operator.typeid",
                "keyword.operator.alignas",
                "keyword.operator.instanceof",
                "keyword.operator.logical.python",
                "keyword.operator.wordlike"
            ],
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": "keyword.other.unit",
            "settings": {
                "foreground": "#d33682"
            }
        },
        {
            "scope": [
                "punctuation.section.embedded.begin.php",
                "punctuation.section.embedded.end.php"
            ],
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": "constant.sha.git-rebase",
            "settings": {
                "foreground": "#d33682"
            }
        },
        {
            "name": "coloring of the Java import and package identifiers",
            "scope": [
                "storage.modifier.import.java",
                "variable.language.wildcard.java",
                "storage.modifier.package.java"
            ],
            "settings": {
                "foreground": "#657b83"
            }
        },
        {
            "name": "this.self",
            "scope": "variable.language",
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "name": "built in properties",
            "scope": [
                "support.constant.property-value",
                "keyword.control.at-rule",
            ],
            "settings": {
                "foreground": "#6c71c4"
            }
        }
    ]
}