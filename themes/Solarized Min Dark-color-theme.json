{
    "name": "Solarized Min Dark",
    "colors": {
        // Base
        "focusBorder": "#2AA19899",
        "selection.background": "#2AA19899",
        "input.background": "#003847",
        "input.foreground": "#839496",
        "input.placeholderForeground": "#839496AA",
        "inputOption.activeBorder": "#2AA19899",
        "inputValidation.infoBorder": "#363b5f",
        "inputValidation.infoBackground": "#052730",
        "inputValidation.warningBackground": "#5d5938",
        "inputValidation.warningBorder": "#9d8a5e",
        "inputValidation.errorBackground": "#571b26",
        "inputValidation.errorBorder": "#a92049",
        "errorForeground": "#ffeaea",
        "badge.background": "#047aa6",
        "progressBar.background": "#047aa6",
        "dropdown.background": "#00212B",
        "dropdown.border": "#2AA19899",
        "button.background": "#2AA19899",
        "list.activeSelectionBackground": "#005A6F",
        "quickInputList.focusBackground": "#005A6F",
        "list.hoverBackground": "#004454AA",
        "list.inactiveSelectionBackground": "#00445488",
        "list.dropBackground": "#00445488",
        "list.highlightForeground": "#1ebcc5",
        // Editor
        "editor.background": "#002B36",
        "editor.foreground": "#839496",
        "editorWidget.background": "#00212B",
        "editorCursor.foreground": "#b58900",
        "editorWhitespace.foreground": "#657b8380",
        "editor.lineHighlightBackground": "#073642",
        "editorLineNumber.foreground": "#8394964d",
        "editorLineNumber.activeForeground": "#839496",
        "editor.selectionBackground": "#268bd240",
        "minimap.selectionHighlight": "#268bd240",
        "editorBracketMatch.background": "#2aa1984d",
        "editorBracketMatch.border": "#2aa1984d",
        "editorRuler.foreground": "#586e754d",
        "editorIndentGuide.background1": "#586e754d",
        "editorIndentGuide.activeBackground1": "#586e75bf",
        "editorHoverWidget.background": "#004052",
        "editorMarkerNavigationError.background": "#AB395B",
        "editorMarkerNavigationWarning.background": "#5B7E7A",
        "editor.selectionHighlightBackground": "#005A6FAA",
        // word match and find highlight colors
        "editor.wordHighlightStrongBackground": "#732b0d80",
        "editor.wordHighlightBackground": "#424d0080",
        "editor.findMatchBackground": "#732b0d99",
        "editor.findMatchHighlightBackground": "#424d0099",
        "editor.rangeHighlightBackground": "#073642cc",
        // Editor: Suggest
        // Editor: Peek View
        "peekViewResult.background": "#00212B",
        "peekViewEditor.background": "#10192c",
        "peekViewTitle.background": "#00212B",
        "peekView.border": "#2b2b4a",
        "peekViewEditor.matchHighlightBackground": "#7744AA40",
        // Editor: Diff
        // Workbench: Title
        "titleBar.activeBackground": "#002C39",
        // Workbench: Editors
        "editorGroup.border": "#00212B",
        "editorGroup.dropBackground": "#2AA19844",
        "editorGroupHeader.tabsBackground": "#004052",
        // Workbench: Tabs
        "tab.activeForeground": "#d6dbdb",
        "tab.activeBackground": "#002B37",
        "tab.inactiveForeground": "#839496",
        "tab.inactiveBackground": "#004052",
        "tab.border": "#003847",
        "tab.lastPinnedBorder": "#2AA19844",
        // Workbench: Activity Bar
        "activityBar.background": "#003847",
        // Workbench: Panel
        "panel.border": "#00212B",
        "panel.background": "#00212B",
        // Workbench: Side Bar
        "sideBar.background": "#00212B",
        "sideBarTitle.foreground": "#839496",
        // Workbench: Status Bar
        "statusBar.foreground": "#839496",
        "statusBar.background": "#00212B",
        "statusBar.debuggingBackground": "#00212B",
        "statusBar.noFolderBackground": "#00212B",
        "statusBarItem.remoteBackground": "#2AA19899",
        "ports.iconRunningProcessForeground": "#369432",
        "statusBarItem.prominentBackground": "#003847",
        "statusBarItem.prominentHoverBackground": "#003847",
        // Workbench: Debug
        "debugToolBar.background": "#00212B",
        "debugExceptionWidget.background": "#00212B",
        "debugExceptionWidget.border": "#AB395B",
        // Workbench: Quick Open
        "pickerGroup.foreground": "#2AA19899",
        "pickerGroup.border": "#2AA19899",
        // Workbench: Terminal
        // Colors sourced from the official palette http://ethanschoonover.com/solarized
        "terminal.foreground": "#839496",
        "terminal.background": "#002b36",
        "terminal.ansiBlack": "#000000",
        "terminal.ansiRed": "#dc322f",
        "terminal.ansiGreen": "#859900",
        "terminal.ansiYellow": "#b58900",
        "terminal.ansiBlue": "#268bd2",
        "terminal.ansiMagenta": "#d33682",
        "terminal.ansiCyan": "#2aa198",
        "terminal.ansiWhite": "#fdf6e3",
        "terminal.ansiBrightBlack": "#000000",
        "terminal.ansiBrightRed": "#dc322f",
        "terminal.ansiBrightGreen": "#859900",
        "terminal.ansiBrightYellow": "#b58900",
        "terminal.ansiBrightBlue": "#268bd2",
        "terminal.ansiBrightMagenta": "#d33682",
        "terminal.ansiBrightCyan": "#2aa198",
        "terminal.ansiBrightWhite": "#fdf6e3",
    },
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "customLiteral": "#839496",
        "newOperator": "#839496",
        "numberLiteral": "#d33682",
        "stringLiteral": "#2aa198"
    },
    "tokenColors": [
        {
            "name": "keyword or other syntax",
            "scope": "punctuation.terminator,constant.character.escape,punctuation.quasi.element",
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "name": "entities",
            "scope": "entity.name,support.type.property-name.json",
            "settings": {
                "foreground": "#6c71c4"
            }
        },
        // {
        //     "scope": "variable.parameter",
        //     "settings": {
        //         "foreground": "#b58900"
        //     }
        // },
        {
            "name": "no highlight",
            "scope": "variable.other,string.unquoted.argument.shell,storage.type.object,storage.type.java,constant.other.option",
            "settings": {
                "foreground": "#839496"
            }
        },
        {
            "scope": "entity.name.function,support.function,keyword.control.twig",
            "settings": {
                "foreground": "#268bd2"
            }
        },
        {
            "scope": [
                "meta.embedded",
                "source.groovy.embedded",
                "string meta.image.inline.markdown",
                "variable.legacy.builtin.python"
            ],
            "settings": {
                "foreground": "#839496"
            }
        },
        {
            "scope": "emphasis",
            "settings": {
                "fontStyle": "italic"
            }
        },
        {
            "scope": "strong",
            "settings": {
                "fontStyle": "bold"
            }
        },
        {
            "name": "Comment",
            "scope": "comment",
            "settings": {
                "foreground": "#586e75",
                "fontStyle": "italic"
            }
        },
        {
            "name": "block comment",
            "scope": "comment.block",
            "settings": {
                "foreground": "#586e75",
                "fontStyle": "italic"
            }
        },
        {
            "scope": "constant.language,variable.other.constant",
            "settings": {
                "foreground": "#d33682"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "variable.other.enummember",
                "keyword.operator.plus.exponent",
                "keyword.operator.minus.exponent",
            ],
            "settings": {
                "foreground": "#d33682"
            }
        },
        {
            "scope": "constant.regexp",
            "settings": {
                "foreground": "#cb4b16"
            }
        },
        {
            "scope": "entity.name.tag",
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": [
                "entity.name.tag.css",
                "entity.name.tag.less"
            ],
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": "entity.other.attribute-name",
            "settings": {
                "foreground": "#6c71c4"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name.class.css",
                "source.css entity.other.attribute-name.class",
                "entity.other.attribute-name.id.css",
                "entity.other.attribute-name.parent-selector.css",
                "entity.other.attribute-name.parent.less",
                "source.css entity.other.attribute-name.pseudo-class",
                "entity.other.attribute-name.pseudo-element.css",
                "source.css.less entity.other.attribute-name.id",
                "entity.other.attribute-name.scss"
            ],
            "settings": {
                "foreground": "#b58900"
            }
        },
        {
            "scope": "invalid",
            "settings": {
                "foreground": "#dc322f"
            }
        },
        {
            "scope": "markup.underline",
            "settings": {
                "fontStyle": "underline"
            }
        },
        {
            "scope": "markup.bold",
            "settings": {
                "fontStyle": "bold",
                "foreground": "#859900"
            }
        },
        {
            "scope": "markup.heading",
            "settings": {
                "fontStyle": "bold",
                "foreground": "#859900"
            }
        },
        {
            "scope": "markup.italic",
            "settings": {
                "fontStyle": "italic"
            }
        },
        {
            "scope": "markup.strikethrough",
            "settings": {
                "fontStyle": "strikethrough"
            }
        },
        {
            "scope": "markup.inserted",
            "settings": {
                "foreground": "#d33682"
            }
        },
        {
            "scope": "markup.deleted",
            "settings": {
                "foreground": "#2aa198"
            }
        },
        {
            "scope": "markup.changed",
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": "punctuation.definition.quote.begin.markdown",
            "settings": {
                "foreground": "#2aa198"
            }
        },
        {
            "scope": "punctuation.definition.list.begin.markdown",
            "settings": {
                "foreground": "#268bd2"
            }
        },
        {
            "scope": "markup.inline.raw",
            "settings": {
                "foreground": "#2aa198"
            }
        },
        {
            "name": "brackets of XML/HTML tags",
            "scope": "punctuation.definition.tag",
            "settings": {
                "foreground": "#657b83"
            }
        },
        {
            "scope": [
                "meta.preprocessor",
                "entity.name.function.preprocessor"
            ],
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": "meta.preprocessor.string",
            "settings": {
                "foreground": "#2aa198"
            }
        },
        {
            "scope": "meta.preprocessor.numeric",
            "settings": {
                "foreground": "#d33682"
            }
        },
        {
            "scope": "meta.diff.header",
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": "storage",
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": "storage.type",
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": [
                "storage.modifier",
                "keyword.operator.noexcept"
            ],
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": [
                "string",
                "meta.embedded.assembly",
            ],
            "settings": {
                "foreground": "#2aa198"
            }
        },
        {
            "scope": "string.tag",
            "settings": {
                "foreground": "#2aa198"
            }
        },
        {
            "scope": "string.value",
            "settings": {
                "foreground": "#2aa198"
            }
        },
        {
            "scope": "string.regexp",
            "settings": {
                "foreground": "#2aa198"
            }
        },
        {
            "name": "String interpolation",
            "scope": [
                "punctuation.definition.template-expression.begin",
                "punctuation.definition.template-expression.end",
                "punctuation.section.embedded"
            ],
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "name": "Reset JavaScript string interpolation expression",
            "scope": [
                "meta.template.expression"
            ],
            "settings": {
                "foreground": "#839496"
            }
        },
        {
            "scope": [
                "support.type.vendored.property-name",
                "support.type.property-name",
                "source.css variable",
                "source.coffee.embedded"
            ],
            "settings": {
                "foreground": "#839496"
            }
        },
        {
            "scope": "keyword",
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": "keyword.control",
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": "keyword.operator",
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": [
                "keyword.operator.new",
                "keyword.operator.expression",
                "keyword.operator.cast",
                "keyword.operator.sizeof",
                "keyword.operator.alignof",
                "keyword.operator.typeid",
                "keyword.operator.alignas",
                "keyword.operator.instanceof",
                "keyword.operator.logical.python",
                "keyword.operator.wordlike"
            ],
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": "keyword.other.unit",
            "settings": {
                "foreground": "#d33682"
            }
        },
        {
            "scope": [
                "punctuation.section.embedded.begin.php",
                "punctuation.section.embedded.end.php"
            ],
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": "constant.sha.git-rebase",
            "settings": {
                "foreground": "#d33682"
            }
        },
        {
            "name": "coloring of the Java import and package identifiers",
            "scope": [
                "storage.modifier.import.java",
                "variable.language.wildcard.java",
                "storage.modifier.package.java"
            ],
            "settings": {
                "foreground": "#839496"
            }
        },
        {
            "name": "this.self",
            "scope": "variable.language",
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "name": "built in properties",
            "scope": [
                "support.constant.property-value",
                "keyword.control.at-rule",
            ],
            "settings": {
                "foreground": "#6c71c4"
            }
        }
    ]
}
